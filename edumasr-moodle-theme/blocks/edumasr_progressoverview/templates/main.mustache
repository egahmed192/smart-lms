{{!
    @template block_edumasr_progressoverview/main

    Course progress overview block - enrolled courses with completion progress.
}}
<div class="block-edumasr-progressoverview" data-region="courseprogressoverview">
    {{#hascourses}}
    <div class="list-group list-group-flush">
        {{#courses}}
        <div class="list-group-item list-group-item-action border-0 px-0 py-2" data-course-id="{{id}}">
            <a href="{{viewurl}}" class="text-decoration-none text-body">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span class="fw-medium text-truncate me-2">{{{fullname}}}</span>
                    {{#hasprogress}}
                    <span class="badge bg-primary rounded-pill flex-shrink-0">{{progress}}%</span>
                    {{/hasprogress}}
                    {{^hasprogress}}
                    <span class="badge bg-secondary rounded-pill flex-shrink-0">{{#str}}notracked, block_edumasr_progressoverview{{/str}}</span>
                    {{/hasprogress}}
                </div>
                {{#showcoursecategory}}
                <div class="small text-muted mb-1">{{{coursecategory}}}</div>
                {{/showcoursecategory}}
                {{#hasprogress}}
                <div class="progress" style="height: 6px;" role="progressbar" aria-valuenow="{{progress}}" aria-valuemin="0" aria-valuemax="100">
                    <div class="progress-bar" style="width: {{progress}}%"></div>
                </div>
                {{/hasprogress}}
            </a>
            {{#hasactivities}}
            <ul class="list-unstyled small mt-1 mb-0 ps-2 border-start border-2 border-light">
                {{#activities}}
                <li class="block-edumasr-progressoverview-activity mb-1">
                    <div class="d-flex align-items-center gap-1">
                        {{#complete}}
                        <span class="text-success flex-shrink-0" aria-label="{{#str}}activitycomplete, block_edumasr_progressoverview{{/str}}">✓</span>
                        {{/complete}}
                        {{^complete}}
                        <span class="text-muted flex-shrink-0" aria-label="{{#str}}activityincomplete, block_edumasr_progressoverview{{/str}}">○</span>
                        {{/complete}}
                        <a href="{{url}}" class="text-truncate flex-grow-1 min-w-0">{{{name}}}</a>
                        <span class="small text-muted flex-shrink-0">{{progress}}%</span>
                    </div>
                    <div class="progress mt-0" style="height: 4px;" role="progressbar" aria-valuenow="{{progress}}" aria-valuemin="0" aria-valuemax="100">
                        <div class="progress-bar" style="width: {{progress}}%"></div>
                    </div>
                </li>
                {{/activities}}
            </ul>
            {{/hasactivities}}
        </div>
        {{/courses}}
    </div>
    {{/hascourses}}
    {{^hascourses}}
    <p class="text-muted small mb-0">{{#str}}nocourses, block_edumasr_progressoverview{{/str}}</p>
    {{/hascourses}}
</div>
