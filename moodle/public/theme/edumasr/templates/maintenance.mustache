{{!
    @template theme_edumasr/maintenance

    Edumasr Academy maintenance layout.
}}
{{{ output.doctype }}}
<html {{{ output.htmlattributes }}}>
<head>
    <title>{{{ output.page_title }}}</title>
    <link rel="shortcut icon" href="{{{ output.favicon }}}" />
    {{{ output.standard_head_html }}}
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>

<body {{{ output.body_attributes }}}>
{{> core/local/toast/wrapper}}

<div id="page-wrapper">

    {{{ output.standard_top_of_body_html }}}

    <div id="page" class="container pb-3">

        <div class="row">
            <div class="col-12 py-3 page-header-headings">
                {{{ output.page_heading }}}
            </div>
        </div>

        <div id="page-content" class="row">
            <div id="region-main" class="col-12">
                {{{ output.main_content }}}
            </div>
        </div>

    </div>
    {{> theme_boost/footer }}
</div>

</body>
</html>
{{#js}}
M.util.js_pending('theme_boost/loader');
require(['theme_boost/loader'], function() {
  M.util.js_complete('theme_boost/loader');
});
{{/js}}
