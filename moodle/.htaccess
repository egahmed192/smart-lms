RewriteEngine On
RewriteBase /moodle/

# Internally rewrite /moodle/ and /moodle/* to public/ so the app is served from public/.
# This avoids running the root index.php (which throws) and makes /moodle/public/ work as /moodle/.
RewriteRule ^$ public/ [L]
RewriteRule ^(?!public/)(.*)$ public/$1 [L]

